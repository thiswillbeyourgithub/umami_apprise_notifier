# Configuration for umami-apprise-notifier systemd service.
# Copy this file to /etc/umami-apprise-notifier.env and fill in your values.

UMAMI_URL=https://analytics.example.com
UMAMI_WEBSITE_ID=your-website-id-here

# Preferred: API key authentication (no login round-trip).
UMAMI_API_KEY=your-api-key-here

# Alternative: username/password (used only when UMAMI_API_KEY is empty).
#UMAMI_USER=admin
#UMAMI_PASSWORD=changeme

# Lookback window in minutes (should match or exceed the timer interval)
UMAMI_SINCE=5

# Apprise notification URL — see https://github.com/caronc/apprise/wiki
# Examples:
#   tgram://bottoken/ChatID
#   slack://tokenA/tokenB/tokenC/#channel
#   mailto://user:pass@gmail.com
APPRISE_URL=tgram://bottoken/ChatID
